@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix waste: <http://example.org/waste-hp#> .
@prefix waste1: <http://example.org/waste#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

waste1:Composting a waste1:DisposalMethod ;
    rdfs:label "Composting" .

waste1:Electronic a waste1:WasteType ;
    rdfs:label "Electronic" ;
    waste1:hazardous true ;
    waste1:recyclable true .

waste1:Glass a waste1:WasteType ;
    rdfs:label "Glass" ;
    waste1:hazardous false ;
    waste1:recyclable true .

waste1:Landfill a waste1:DisposalMethod ;
    rdfs:label "Landfill" .

waste1:Metal a waste1:WasteType ;
    rdfs:label "Metal" ;
    waste1:hazardous false ;
    waste1:recyclable true .

waste1:Organic a waste1:WasteType ;
    rdfs:label "Organic" ;
    waste1:hazardous false ;
    waste1:recyclable false .

waste1:Paper a waste1:WasteType ;
    rdfs:label "Paper" ;
    waste1:hazardous false ;
    waste1:recyclable true .

waste1:Plastic a waste1:WasteType ;
    rdfs:label "Plastic" ;
    waste1:hazardous false ;
    waste1:recyclable true .

waste1:Recycling a waste1:DisposalMethod ;
    rdfs:label "Recycling" .

waste1:RecyclingFacility a owl:Class ;
    rdfs:label "Recycling Facility" ;
    rdfs:comment "A facility that processes recyclable materials" .

waste1:SpecialCollection a waste1:DisposalMethod ;
    rdfs:label "Special Collection" .

waste1:WasteOntology a owl:Ontology ;
    rdfs:label "Waste Management Ontology" ;
    rdfs:comment "Ontology for waste classification and recycling knowledge" .

waste1:decompositionTime a owl:DatatypeProperty ;
    rdfs:label "decomposition time" ;
    rdfs:domain waste1:Material ;
    rdfs:range xsd:string .

waste1:hasDisposalMethod a owl:ObjectProperty ;
    rdfs:label "has disposal method" ;
    rdfs:domain waste1:WasteType ;
    rdfs:range waste1:DisposalMethod .

waste1:hasMaterial a owl:ObjectProperty ;
    rdfs:label "has material" ;
    rdfs:domain waste1:WasteType ;
    rdfs:range waste1:Material .

waste1:hazardous a owl:DatatypeProperty ;
    rdfs:label "is hazardous" ;
    rdfs:domain waste1:WasteType ;
    rdfs:range xsd:boolean .

waste1:recyclable a owl:DatatypeProperty ;
    rdfs:label "is recyclable" ;
    rdfs:domain waste1:WasteType ;
    rdfs:range xsd:boolean .

waste:waste_06_01_01_star a waste:WasteEntry ;
