    waste:description "sulphuric acid and sulphurous acid" ;
    waste:hasEntryType waste:AbsoluteHazardous ;
    waste:hasHP waste:HP8 ;
    waste:lowCode "06 01 01*" ;
    waste:subchapter "06 01" .

